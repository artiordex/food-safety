{
  "name": "foodsafetykorea-crawler",
  "version": "1.0.0",
  "description": "Playwright & HTTP crawler pipeline for FoodSafetyKorea",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "crawl": "node crawler/crawler_api.js",
    "report": "chcp 65001 && node crawler/crawler_and_report.js",
    "db:import": "node db/import_to_sqlite.js",
    "db:analyze": "node db/analyze_pk_fk.js",
    "db:check-joins": "node db/check_joins.js",
    "db:generate-sql": "node db/generate_json_sql.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "arquero": "^8.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fuse.js": "^7.4.2",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-dag": "^0.4.1",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "infer-types": "^0.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pptxgenjs": "^4.0.1",
    "simple-statistics": "^7.9.0",
    "sqlite3": "^5.1.7",
    "string-similarity": "^4.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cheerio": "^1.0.0-rc.12",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.42.1"
  }
}

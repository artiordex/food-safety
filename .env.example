# 식품안전나라 OpenAPI 인증키
# https://www.foodsafetykorea.go.kr/api/openApiInfo.do 에서 발급
FOOD_API_KEY=your_api_key_here

# 서버 포트 (기본값 8000)
PORT=8000

# 로그 레벨 (trace | debug | info | warn | error)
LOG_LEVEL=info

# 허용할 CORS 도메인 목록 (쉼표로 구분)
# 로컬 개발 시: 생략 가능 (localhost 자동 허용)
# 운영 서버 배포 시: 반드시 실제 도메인으로 설정
ALLOWED_ORIGINS=https://food-safety-muxr.onrender.com
